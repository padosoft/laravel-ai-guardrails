{
    "name": "padosoft/laravel-ai-guardrails",
    "description": "Deterministic prompt-injection guardrails for laravel/ai: tool firewall, input screening + injection audit, untrusted-output sanitization, and a HITL approval bridge.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["laravel", "ai", "prompt-injection", "guardrails", "ai-safety", "hitl"],
    "homepage": "https://github.com/padosoft/laravel-ai-guardrails",
    "support": {
        "issues": "https://github.com/padosoft/laravel-ai-guardrails/issues",
        "source": "https://github.com/padosoft/laravel-ai-guardrails"
    },
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "laravel/ai": "^0.8"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.5|^12.0",
        "padosoft/laravel-flow": "^1.0",
        "padosoft/laravel-pii-redactor": "^1.0"
    },
    "suggest": {
        "padosoft/laravel-flow": "Enables the HITL approval bridge (control D) via approvalGate().",
        "padosoft/laravel-pii-redactor": "Enables PII redaction in the output handler (control C)."
    },
    "autoload": { "psr-4": { "Padosoft\\AiGuardrails\\": "src/" } },
    "autoload-dev": { "psr-4": { "Padosoft\\AiGuardrails\\Tests\\": "tests/" } },
    "extra": {
        "laravel": {
            "providers": ["Padosoft\\AiGuardrails\\AiGuardrailsServiceProvider"],
            "aliases": { "AiGuardrails": "Padosoft\\AiGuardrails\\Facades\\AiGuardrails" }
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "format": "pint",
        "format:test": "pint --test"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": { "infection/infection": true }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
